# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Pooled connection string from the Neon dashboard (ends with ?sslmode=require)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL, used to build Apify webhook callback URLs.
APP_BASE_URL="http://localhost:3000"

# Shared secret guarding cron + webhook routes. Generate a long random string.
CRON_SECRET="change-me-to-a-long-random-string"
APIFY_WEBHOOK_SECRET="change-me-to-another-long-random-string"

# ─── Apify (optional in MVP) ──────────────────────────────────────────────────
# When empty, the pipeline runs in MOCK mode using local fixtures.
APIFY_TOKEN=""
# Actor that scrapes Trustpilot reviews (e.g. "nikita-sviridenko/trustpilot-reviews-scraper").
APIFY_TRUSTPILOT_ACTOR=""
# Actor used as the crawl fetch fallback when a direct fetch() is empty/blocked.
APIFY_CRAWLER_ACTOR="apify/website-content-crawler"

# ─── AI (crawl extraction + diff summaries; MOCK when key empty) ──────────────
ANTHROPIC_API_KEY=""
# Model for crawl extraction/diff. Default claude-opus-4-8; claude-haiku-4-5 is a
# cheaper pick for this high-volume structured-extraction workload.
ANTHROPIC_CRAWL_MODEL="claude-opus-4-8"

# ─── Paddle Billing (subscriptions; manual mode when key empty) ───────────────
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
PADDLE_ENV="sandbox"                 # sandbox | production
# Paddle price id per package tier (from your Paddle catalogue).
PADDLE_PRICE_STARTER=""
PADDLE_PRICE_GROWTH=""
PADDLE_PRICE_PRO=""