# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Pooled connection string from the Neon dashboard (ends with ?sslmode=require)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL, used to build Apify webhook callback URLs.
APP_BASE_URL="http://localhost:3000"

# Shared secret guarding cron + webhook routes. Generate a long random string.
CRON_SECRET="change-me-to-a-long-random-string"
APIFY_WEBHOOK_SECRET="change-me-to-another-long-random-string"

# ─── Apify (optional in MVP) ──────────────────────────────────────────────────
# When empty, the pipeline runs in MOCK mode using local fixtures.
APIFY_TOKEN=""
# Actor that scrapes Trustpilot reviews (e.g. "nikita-sviridenko/trustpilot-reviews-scraper").
APIFY_TRUSTPILOT_ACTOR=""

# ─── AI (later phase) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Paddle (later phase) ─────────────────────────────────────────────────────
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""